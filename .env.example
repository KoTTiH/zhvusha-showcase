# ZHVUSHA public showcase environment template.
# Copy to .env and fill only the values you need for local evaluation.

# Telegram bot credentials.
BOT_TOKEN=your_bot_token
CHANNEL_ID=@your_channel
ADMIN_USER_ID=0
TELEGRAM_BOT_PROXY=

# LLM providers. Keep empty unless you run provider-specific paths.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional provider experiments.
NVIDIA_NIM_API_KEY=
HUGGINGFACE_API_KEY=
MINIMAX_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Local infrastructure.
DATABASE_URL=postgresql+asyncpg://zhvusha:zhvusha_dev@localhost:5432/zhvusha
REDIS_URL=redis://localhost:6379/0
WORKSPACE_PATH=~/zhvusha-workspace-demo
ZHVUSHA_WORKSPACE_PATH=~/zhvusha-workspace-demo
PROJECT_PATH=~/Projects/zhvusha-showcase

# Public assistant info shown to non-owner users.
PUBLIC_INFO_ABOUT_OWNER=Project owner builds bots, web apps and AI integrations.
PUBLIC_CONTACT_OWNER=
PUBLIC_INFO_ABOUT_NIKITA=Project owner builds bots, web apps and AI integrations.
PUBLIC_CONTACT_NIKITA=

# LLM tier routing.
CODEX_CLI_PATH=codex
WORKER_PROVIDER=codex_cli
WORKER_MODEL=default
WORKER_REASONING_EFFORT=medium
ANALYST_PROVIDER=codex_cli
ANALYST_MODEL=default
ANALYST_REASONING_EFFORT=high
STRATEGIST_PROVIDER=codex_cli
STRATEGIST_MODEL=default
STRATEGIST_REASONING_EFFORT=xhigh
VISION_PROVIDER=gemini
VISION_MODEL=gemini-2.5-flash-lite
DEFAULT_LLM_TIER=worker

# Code agent backend. Disabled by default in the public snapshot.
CODE_AGENT_BACKEND=codex_cli
CODE_AGENT_MODEL=
CODE_AGENT_REASONING_EFFORT=xhigh
CODE_AGENT_TIMEOUT_SECONDS=7200
CODE_AGENT_MAX_CONCURRENT=1
SELF_CODING_ENABLED=false
SELF_CODING_REQUIRE_APPROVAL=true
SELF_CODING_MAX_TIER=1

# Budgets and runtime limits.
STRATEGIST_BUDGET_DAILY_USD=1.20
DAEMON_MAX_LLM_COST_PER_DAY_USD=0.50
DAEMON_MAX_LLM_CALLS_PER_HOUR=30
AUTONOMOUS_LOOP_BUDGET_DAILY_USD=1.0
AUTONOMOUS_LOOP_BUDGET_WEEKLY_USD=5.0
AUTONOMOUS_SELF_CODING_BUDGET_DAILY_USD=2.0
AUTONOMOUS_SELF_CODING_BUDGET_WEEKLY_USD=8.0
AUTONOMOUS_DAY_WINDOW_START_HOUR=10
AUTONOMOUS_DAY_WINDOW_DURATION_HOURS=12
AUTONOMOUS_LOOP_MAX_JOBS_PER_DAY=12
AUTONOMOUS_LOOP_MAX_RUNTIME_SECONDS_PER_DAY=43200
AUTONOMOUS_LOOP_MAX_RETRIES_PER_JOB=2
AUTONOMOUS_LOOP_MAX_CONCURRENT_JOBS=1
AUTONOMOUS_SELF_CODING_MAX_JOBS_PER_DAY=2
AUTONOMOUS_SELF_CODING_MAX_RUNTIME_SECONDS_PER_DAY=43200

# Background/runtime systems. Safe/off by default.
DAEMON_ENABLED=false
DAEMON_AGENT_RUNTIME_ENABLED=false
DAEMON_DECISION_TIER=worker
DAEMON_SLEEP_AGENT_TIER=worker
LIFE_RUNTIME_ENABLED=false
LIFE_RUNTIME_STATE_PATH=~/zhvusha-workspace-demo/life_runtime
LIFE_RUNTIME_MIN_TICK_INTERVAL_SECONDS=300
LIFE_RUNTIME_MAX_TICKS_PER_HOUR=12

# Browser, computer-use and external actions. Safe/off by default.
ENABLE_BROWSER_USE=false
BROWSER_BACKEND=browser_use
BROWSER_HTTP_PROXY=
DESKTOP_CONTROL_ENABLED=false
DESKTOP_CONTROL_COMMAND_MAP_JSON=
DESKTOP_CONTROL_COMMAND_TIMEOUT_SECONDS=10
COMPUTER_USE_ENABLED=false
COMPUTER_USE_IRREVERSIBLE_POLICY=hard_stop
COMPUTER_USE_SHELL_ENABLED=false
COMPUTER_USE_SHELL_ALLOWED_EXECUTABLES=
COMPUTER_USE_SHELL_TIMEOUT_SECONDS=10
LIVE_BROWSER_CONTROL_ENABLED=false
LIVE_BROWSER_BACKEND=chrome_devtools_mcp
LIVE_BROWSER_DEBUG_URL=http://127.0.0.1:9222
LIVE_BROWSER_AUTO_LAUNCH=false
LIVE_BROWSER_EXECUTABLE=chromium
LIVE_BROWSER_USER_DATA_DIR=~/zhvusha-workspace-demo/live-chrome
LIVE_BROWSER_HEADLESS=false

# Memory and enrichment.
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RECENCY_HALF_LIFE_PERSONAL=48
RECENCY_HALF_LIFE_ASSISTANT=24
RECENCY_HALF_LIFE_SOCIAL=12
RECONSOLIDATION_WINDOW_HOURS=6
ENRICHMENT_TIER=worker
ENRICHMENT_MIN_LENGTH=15
ENRICHMENT_MAX_CONCURRENT=3
DREAM_EXTRACTION_TIER=worker
SYSTEM1_DEFAULT_THRESHOLD=0.7
CONSOLIDATION_TOP_N=300
CORE_MD_MAX_LINES=100
MEMORY_INDEX_MAX_LINES=200
MEMORY_INDEX_MAX_KB=25

# Chat behavior.
CHAT_ASSISTANT_TIER=worker
CHAT_AGENTIC_TIMEOUT_SECONDS=300
CHAT_DECISION_CONTEXT_TIMEOUT_SECONDS=8
ASSISTANT_DAILY_MESSAGE_LIMIT=30

# Collectors. Disabled by default.
FIREFOX_PROFILE_PATH=
CHROME_HISTORY_PATH=
YOUTUBE_TAKEOUT_PATH=
YOUTUBE_API_KEY=
YOUTUBE_SCAN_ENABLED=false
YOUTUBE_TRANSCRIBE_TOP_N=3
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELETHON_SESSION_PATH=~/.zhvusha_demo_telethon.session
MONITORED_CHANNEL_IDS=
CHANNEL_READ_DELAY_SECONDS=1.5

# News/topic pipeline.
NEWS_SOURCES_ENABLED=false
NEWS_POLL_INTERVAL_SECONDS=3600
NEWS_RAW_STREAM=news:raw
NEWS_ARXIV_RSS_URL=https://rss.arxiv.org/rss/cs.AI+cs.CL+cs.SE
NEWS_RSS_URLS=
PILLARS_PATH=~/zhvusha-workspace-demo/personality/pillars.md

# Optional business-opportunity monitor. Disabled unless configured in code.
KWORK_LOGIN=
KWORK_PASSWORD=
KWORK_PHONE_LAST=
KWORK_POLL_INTERVAL_SECONDS=300
KWORK_MIN_BUDGET=3000
KWORK_MAX_OFFERS=15
KWORK_KEYWORDS=python,telegram,bot,react,fastapi,ai

# Agent Runtime integrations. Safe/off by default.
DELEGATE_ENABLED=false
DELEGATE_MODEL=
DELEGATE_CWD=~/Projects/zhvusha-showcase
TELEGRAM_MCP_ENABLED=false
TELEGRAM_MCP_ALLOWED_ROOTS=~/zhvusha-workspace-demo/telegram-mcp
TELEGRAM_MCP_ACCOUNT_LABEL=personal
PERSONAL_TELEGRAM_INBOUND_ENABLED=false
PERSONAL_TELEGRAM_INBOUND_STORE_PATH=~/zhvusha-workspace-demo/telegram/inbound_events.jsonl
AGENCY_PERMISSION_STORE_PATH=~/zhvusha-workspace-demo/agency/permissions.jsonl

# Image generation. Disabled by default.
IMAGE_GENERATION_ENABLED=false
IMAGE_GENERATION_PROVIDER=cli
IMAGE_GENERATION_CLI_COMMAND=
IMAGE_GENERATION_CLI_TIMEOUT_SECONDS=300
IMAGE_GENERATION_MODEL=
IMAGE_GENERATION_SIZE=1024x1024

# Dashboard.
DASHBOARD_UPDATE_INTERVAL_SECONDS=30
